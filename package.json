{
  "name": "mikrodex",
  "version": "1.0.1",
  "description": "Modern Dark Futuristic MikroTik Hotspot Manager Desktop App",
  "main": "electron/main.js",
  "homepage": "https://mikrodex.pro.bd/",
  "scripts": {
    "predeploy": "npm run build && New-Item -Path \"dist\\.nojekyll\" -ItemType \"file\" -Force",
    "deploy": "gh-pages -d dist -t",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron-build": "npm run build && electron-builder",
    "lint": "eslint src",
    "format": "prettier --write ."
  },
  "build": {
    "appId": "com.mikrodex.app",
    "productName": "MikroDex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.292.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^4.0.1",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.8.1",
    "sqlite": "^5.0.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.37.5",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
